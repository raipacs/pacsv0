# Public HTTPS hostname for Orthanc REST/DICOMweb through Caddy.
# Example: dicom.raipacs.com
RAI_DICOMWEB_HOSTNAME=dicom.raipacs.com

# Orthanc REST/DICOMweb password for user rai-admin.
# Replace before starting the VM.
RAI_ORTHANC_PASSWORD=change-this-password

# RAI import bridge values used when this repo is copied to the VM.
RAI_PACS_ORTHANC_URL=https://dicom.raipacs.com
RAI_PACS_ORTHANC_USERNAME=rai-admin
RAI_PACS_ORTHANC_PASSWORD=change-this-password
RAI_PACS_ORTHANC_STUDY_ID=
RAI_PACS_ORTHANC_STUDY_UID=
RAI_PACS_ORTHANC_DELETE_AFTER_IMPORT=false

# RAI app import credentials. Do not commit real values.
RAI_PACS_SUPABASE_URL=
RAI_PACS_SUPABASE_PUBLISHABLE_KEY=
RAI_PACS_IMPORT_EMAIL=
RAI_PACS_IMPORT_PASSWORD=
